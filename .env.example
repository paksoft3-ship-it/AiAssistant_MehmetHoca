# ─────────────────────────────────────────────────────────────
# EidosUs — environment configuration template
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Server-side only. The Gemini API key MUST stay on the server; it is never
# exposed to the client bundle.
GEMINI_API_KEY=

# Gemini model id. Read from config with a safe default; do not hardcode in code.
GEMINI_MODEL=gemini-3.5-flash

# Express server port.
PORT=3000

# Master switch for all AI features on the server.
AI_FEATURES_ENABLED=true

# Optional cloud (later-stage; not required for the local MVP).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Client feature flags (exposed to the browser via Vite; safe, non-secret) ──
# Leave unset to use built-in defaults. Figure explanation is OFF by default.
VITE_AI_FEATURES_ENABLED=true
VITE_FEATURE_AI_NOTE_CLEANING=true
VITE_FEATURE_TRANSLATION=true
VITE_FEATURE_DISCUSSION=true
VITE_FEATURE_HANDS_FREE=true
VITE_FEATURE_FIGURE_EXPLANATION=false
VITE_FEATURE_CLOUD_AUTH=false
